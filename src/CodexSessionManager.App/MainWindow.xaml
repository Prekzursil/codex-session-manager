<Window x:Class="CodexSessionManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Codex Session Manager"
        Height="950"
        Width="1650"
        MinHeight="800"
        MinWidth="1300">
    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="270" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Name="RefreshButton"
                            Margin="0,0,8,0"
                            Padding="12,6"
                            Click="RefreshButton_OnClick"
                            Content="Refresh" />
                    <Button Name="DeepScanButton"
                            Margin="0,0,8,0"
                            Padding="12,6"
                            Click="DeepScanButton_OnClick"
                            Content="Deep Scan" />
                    <Button Name="ExportButton"
                            Padding="12,6"
                            Click="ExportButton_OnClick"
                            Content="Export Session" />
                </StackPanel>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Text="Codex Session Manager" />
                    <TextBlock Name="StatusTextBlock"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="Starting…" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel>
                    <TextBox Name="SearchTextBox"
                             DockPanel.Dock="Top"
                             Margin="0,0,0,12"
                             Padding="10"
                             TextChanged="SearchTextBox_OnTextChanged" />

                    <ListBox Name="SessionsListBox"
                             SelectionMode="Extended"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="SessionsListBox_OnSelectionChanged" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="16,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <TabControl>
                    <TabItem Header="Readable">
                        <TextBox Name="ReadableTranscriptTextBox"
                                 Padding="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True" />
                    </TabItem>
                    <TabItem Header="Dialogue">
                        <TextBox Name="DialogueTranscriptTextBox"
                                 Padding="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True" />
                    </TabItem>
                    <TabItem Header="Audit">
                        <TextBox Name="AuditTranscriptTextBox"
                                 Padding="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True" />
                    </TabItem>
                    <TabItem Header="Raw">
                        <TextBox Name="RawTranscriptTextBox"
                                 Padding="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 AcceptsTab="True" />
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Session Details" />

                        <TextBlock Margin="0,16,0,4"
                                   FontWeight="SemiBold"
                                   Text="Title" />
                        <TextBlock Name="ThreadNameTextBlock"
                                   Text="-" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Session ID" />
                        <TextBlock Name="SessionIdTextBlock"
                                   Text="-" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Preferred Path" />
                        <TextBlock Name="PreferredPathTextBlock"
                                   TextWrapping="Wrap"
                                   Text="-" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="CWD" />
                        <TextBlock Name="CwdTextBlock"
                                   TextWrapping="Wrap"
                                   Text="-" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Live SQLite Status" />
                        <TextBlock Name="SQLiteStatusTextBlock"
                                   TextWrapping="Wrap"
                                   Text="-" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Physical Copies" />
                        <ListBox Name="CopiesListBox"
                                 Height="120"
                                 DisplayMemberPath="FilePath" />

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,12,0,0">
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Click="OpenFolderButton_OnClick"
                                    Content="Open Folder" />
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Click="OpenRawButton_OnClick"
                                    Content="Open Raw" />
                            <Button Padding="10,6"
                                    Click="CopyPathButton_OnClick"
                                    Content="Copy Path" />
                        </StackPanel>

                        <Button Margin="0,8,0,0"
                                Padding="10,6"
                                Click="ResumeButton_OnClick"
                                Content="Resume in Codex" />

                        <Separator Margin="0,16,0,16" />

                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Aliases / Tags / Notes" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Alias" />
                        <TextBox Name="AliasTextBox"
                                 Padding="8" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Tags (comma separated)" />
                        <TextBox Name="TagsTextBox"
                                 Padding="8" />

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Notes" />
                        <TextBox Name="NotesTextBox"
                                 Padding="8"
                                 Height="100"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />

                        <Button Margin="0,12,0,0"
                                Padding="10,6"
                                Click="SaveMetadataButton_OnClick"
                                Content="Save Metadata" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="12"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Advanced Maintenance" />
                    <TextBlock Margin="0,8,0,4"
                               Foreground="#6B7280"
                               Text="Type-aware preview with checkpoint + typed confirm." />

                    <TextBlock Margin="0,16,0,4"
                               FontWeight="SemiBold"
                               Text="Action" />
                    <ComboBox Name="MaintenanceActionComboBox"
                              SelectedIndex="0" />

                    <TextBlock Margin="0,16,0,4"
                               FontWeight="SemiBold"
                               Text="Destination Root" />
                    <TextBox Name="DestinationRootTextBox"
                             Padding="8" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="16,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Preview Summary" />
                    <TextBlock Name="MaintenanceSummaryTextBlock"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="No preview generated yet." />

                    <TextBlock Margin="0,16,0,4"
                               FontWeight="SemiBold"
                               Text="Warnings" />
                    <TextBox Name="MaintenanceWarningsTextBox"
                             Height="120"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True" />

                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0">
                        <Button Margin="0,0,8,0"
                                Padding="10,6"
                                Click="BuildPreviewButton_OnClick"
                                Content="Build Preview" />
                        <Button Padding="10,6"
                                Click="ExecuteMaintenanceButton_OnClick"
                                Content="Execute" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold"
                               Text="Typed Confirmation" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#6B7280"
                               Text="Must exactly match the generated confirmation phrase." />
                    <TextBox Name="TypedConfirmationTextBox"
                             Margin="0,12,0,0"
                             Padding="8" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
